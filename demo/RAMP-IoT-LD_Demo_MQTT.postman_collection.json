{
  "info": {
    "_postman_id": "c21c42a0-4867-4b94-8f48-bfa9ce27d940",
    "name": "RAMP-IoT-LD Demo - MQTT IoT Agent",
    "description": "Postman collection for RAMP-IoT-LD Demo with MQTT IoT Agent. This collection includes requests to interact with IoT Agent MQTT, Orion-LD Context Broker and Mintaka temporal API for ENERGY_METER sensors. Run the setup_demo_mqtt.sh command to generate the testing data.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "9192452"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Get Orion Token from Keycloak",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set(\"orion_token\", jsonData.access_token);",
                  "    console.log(\"Orion token saved:\", jsonData.access_token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "{{keycloak_username}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{keycloak_password}}",
                  "type": "text"
                },
                {
                  "key": "grant_type",
                  "value": "password",
                  "type": "text"
                },
                {
                  "key": "client_id",
                  "value": "{{orion_client_id}}",
                  "type": "text"
                },
                {
                  "key": "client_secret",
                  "value": "{{orion_client_secret}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "https://{{HOST}}:{{KEYCLOAK_TLS_PORT}}/realms/fiware-server/protocol/openid-connect/token",
              "protocol": "https",
              "host": [
                "{{HOST}}"
              ],
              "port": "{{KEYCLOAK_TLS_PORT}}",
              "path": [
                "realms",
                "fiware-server",
                "protocol",
                "openid-connect",
                "token"
              ]
            }
          },
          "response": []
        },
