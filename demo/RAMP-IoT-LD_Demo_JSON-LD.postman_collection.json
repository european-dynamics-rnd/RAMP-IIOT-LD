	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Get Orion Token from Keycloak",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.collectionVariables.set(\"orion_token\", jsonData.access_token);",
									"    console.log(\"Orion token saved:\", jsonData.access_token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/x-www-form-urlencoded"
							}
						],
						"body": {
							"mode": "urlencoded",
							"urlencoded": [
								{
									"key": "username",
									"value": "{{keycloak_username}}",
									"type": "text"
								},
								{
									"key": "password",
									"value": "{{keycloak_password}}",
									"type": "text"
								},
								{
									"key": "grant_type",
									"value": "password",
									"type": "text"
								},
								{
									"key": "client_id",
									"value": "{{orion_client_id}}",
									"type": "text"
								},
								{
									"key": "client_secret",
									"value": "{{orion_client_secret}}",
									"type": "text"
								}
							]
						},
						"url": {
							"raw": "https://{{HOST}}:{{KEYCLOAK_TLS_PORT}}/realms/fiware-server/protocol/openid-connect/token",
							"protocol": "https",
							"host": [
								"{{HOST}}"
							],
							"port": "{{KEYCLOAK_TLS_PORT}}",
							"path": [
								"realms",
								"fiware-server",
								"protocol",
								"openid-connect",
								"token"
							]
						}
					},
					"response": []
				},
