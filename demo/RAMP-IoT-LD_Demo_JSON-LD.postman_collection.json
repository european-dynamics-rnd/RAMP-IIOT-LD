						"body": {
							"mode": "raw",
							"raw": "[\n  {\n    \"id\": \"urn:ngsi-ld:PM_SENSOR:pm_sensor-001\",\n    \"type\": \"PM_SENSOR\",\n    \"pm25\": {\n      \"type\": \"Property\",\n      \"value\": 32.9,\n      \"unitCode\": \"GQ\",\n      \"observedAt\": \"2026-02-09T12:00:00Z\"\n    },\n    \"temperature\": {\n      \"type\": \"Property\",\n      \"value\": 29.4,\n      \"unitCode\": \"CEL\",\n      \"observedAt\": \"2026-02-09T12:00:00Z\"\n    },\n    \"relativeHumidity\": {\n      \"type\": \"Property\",\n      \"value\": 31.1,\n      \"unitCode\": \"P1\",\n      \"observedAt\": \"2026-02-09T12:00:00Z\"\n    },\n    \"dateObserved\": {\n      \"type\": \"Property\",\n      \"value\": {\n        \"@type\": \"DateTime\",\n        \"@value\": \"2026-02-09T12:00:00Z\"\n      }\n    },\n    \"@context\": [\n      \"{{CONTEXT}}\",\n      \"{{CORE_CONTEXT}}\"\n    ]\n  }\n]"
						},
						"url": {
							"raw": "http://{{HOST}}:{{ORION_LD_PORT}}/ngsi-ld/v1/entityOperations/upsert",
							"protocol": "http",
							"host": [
